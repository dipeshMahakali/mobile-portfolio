{
  "expo": {
    "name": "dipesh-patel-portfolio",
    "slug": "personal-portfolio",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/brain-chip-circuit-white-bg-padded.png",
    "scheme": "myreactnativeapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dipeshpatelsteam.personalportfolio",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/brain-chip-circuit-padded.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.dipeshpatelsteam.personalportfolio"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/brain-chip-circuit.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/brain-chip-circuit.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "image": "./assets/images/brain-chip-circuit-white.png",
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2c527e6d-c761-4048-b9a5-13f52544930a"
      }
    },
    "owner": "dipesh-patels-team"
  }
}
